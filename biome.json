{
  "$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
  "formatter": {
    "enabled": true,
    "ignore": ["dist", "coverage", "node_modules"],
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "quoteStyle": "single",
    "semicolons": "never",
    "trailingCommas": "all",
    "arrowParentheses": "always"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "error",
        "noNamespace": "error",
        "noNestedTernary": "error",
        "useConst": "error",
        "noVar": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUndeclaredDependencies": "error",
        "noConsole": "warn",
        "noDebugger": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noImplicitAnyLet": "error",
        "noVoidTypeReturn": "error",
        "noAssignInExpressions": "error"
      },
      "complexity": {
        "noExtraBooleanCast": "warn",
        "noNegationElse": "warn"
      }
    }
  },
  "organizeImports": {
    "enabled": true
  },
  "javascript": {
    "formatter": {
      "enabled": true,
      "lineWidth": 100,
      "semicolons": "never",
      "trailingCommas": "all",
      "indentWidth": 2,
      "indentStyle": "space",
      "arrowParentheses": "always",
      "quoteStyle": "single"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentWidth": 2
    },
    "linter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "include": ["*.test.ts", "*.test.tsx", "**/*.test.ts", "**/*.test.tsx"],
      "linter": {
        "rules": {
          "correctness": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "include": ["**/scripts/*.ts", "**/*.config.{js,ts,cjs,mjs}"],
      "linter": {
        "rules": {
          "correctness": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
};
